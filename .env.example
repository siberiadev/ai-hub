# --- ClaudeClientService (Фаза 1) ---
# Путь/имя бинаря claude (по умолчанию берётся из PATH)
CLAUDE_BIN=claude
# Рабочая директория для процессов claude (по умолчанию — cwd приложения)
CLAUDE_WORKSPACE=
# Permission mode: default | acceptEdits | auto | bypassPermissions | dontAsk | plan
CLAUDE_PERMISSION_MODE=default
# Таймаут одного хода, мс
CLAUDE_TIMEOUT_MS=120000
# true → не грузить MCP-серверы (быстрее старт, но без Gmail и пр. интеграций)
CLAUDE_STRICT_MCP=false
# Путь/JSON с курируемым набором MCP (работает только при CLAUDE_STRICT_MCP=true)
CLAUDE_MCP_CONFIG=
# Постоянный процесс на сессию (быстрее: холодный старт один раз). false → one-shot на каждый ход
CLAUDE_PERSISTENT=true
# Выселение простаивающего процесса, мс (только persistent)
CLAUDE_IDLE_TTL_MS=300000
# Потолок одновременно живых процессов claude (LRU-выселение)
CLAUDE_MAX_PROCS=3
# ASK-протокол: уточняющие вопросы Claude с вариантами → inline-кнопки в Telegram
CLAUDE_ASK_ENABLED=true

# --- SessionService (Фаза 2) ---
# Путь к SQLite-файлу сессий (по умолчанию ./data/ai-hub.db; в тестах ':memory:')
DB_PATH=

# --- Telegram (Фаза 4) ---
# Токен бота от @BotFather. Пусто → бот выключен (приложение работает без него).
TELEGRAM_BOT_TOKEN=
# Разрешённые Telegram user id через запятую (узнать свой: напишите боту — он покажет id).
TELEGRAM_ALLOWED_USER_IDS=
# Рендерить финальный ответ как rich-сообщение (нативные таблицы/заголовки; Bot API 10.1+).
# false → обычный текст. Фолбэк на текст срабатывает и автоматически при ошибке rich.
TELEGRAM_RICH=true

# --- Голосовые сообщения / STT (Фаза 9) ---
# true → распознавать голосовые локальным whisper.cpp (нужны ffmpeg + whisper-cli + модель).
WHISPER_ENABLED=false
# Путь к бинарю whisper.cpp (например /opt/whisper.cpp/build/bin/whisper-cli)
WHISPER_BIN=whisper-cli
# Путь к ggml-модели (например /opt/whisper.cpp/models/ggml-medium-q5_0.bin)
WHISPER_MODEL=
# Язык распознавания: auto | ru | en | ...
WHISPER_LANG=auto
# Число потоков whisper (по числу vCPU)
WHISPER_THREADS=2
# Таймаут распознавания, мс
WHISPER_TIMEOUT_MS=120000
# Путь/имя ffmpeg
FFMPEG_BIN=ffmpeg

# ОПЦИОНАЛЬНО (контейнеры/CI). Основной путь — авторизация на сервере через `claude /login`
# под тем же пользователем, что и сервис: тогда токен НЕ нужен (claude берёт креды из ~/.claude/,
# на mac — из keychain). Задайте только если не хотите интерактивный логин на машине.
# CLAUDE_CODE_OAUTH_TOKEN=
# ВАЖНО: НЕ задавать ANTHROPIC_API_KEY — иначе оплата по токенам через API.
