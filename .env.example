# --- ClaudeClientService (Фаза 1) ---
# Путь/имя бинаря claude (по умолчанию берётся из PATH)
CLAUDE_BIN=claude
# Рабочая директория для процессов claude (по умолчанию — cwd приложения)
CLAUDE_WORKSPACE=
# Permission mode: default | acceptEdits | auto | bypassPermissions | dontAsk | plan
CLAUDE_PERMISSION_MODE=default
# Таймаут одного хода, мс. Для агентных кодовых задач (read→edit→bash) ставь больше.
CLAUDE_TIMEOUT_MS=600000
# true → не грузить MCP-серверы (быстрее старт, но без Gmail и пр. интеграций)
CLAUDE_STRICT_MCP=false
# Путь/JSON с курируемым набором MCP (работает только при CLAUDE_STRICT_MCP=true)
CLAUDE_MCP_CONFIG=
# Постоянный процесс на сессию (быстрее: холодный старт один раз). false → one-shot на каждый ход
CLAUDE_PERSISTENT=true
# Выселение простаивающего процесса, мс (только persistent)
CLAUDE_IDLE_TTL_MS=300000
# Потолок одновременно живых процессов claude (LRU-выселение)
CLAUDE_MAX_PROCS=3
# ASK-протокол: уточняющие вопросы Claude с вариантами → inline-кнопки в Telegram
CLAUDE_ASK_ENABLED=true

# --- SessionService (Фаза 2) ---
# Путь к SQLite-файлу сессий (по умолчанию ./data/ai-hub.db; в тестах ':memory:')
DB_PATH=

# --- Telegram (Фаза 4) ---
# Токен бота от @BotFather. Пусто → бот выключен (приложение работает без него).
TELEGRAM_BOT_TOKEN=
# Разрешённые Telegram user id через запятую (узнать свой: напишите боту — он покажет id).
TELEGRAM_ALLOWED_USER_IDS=
# Рендерить финальный ответ как rich-сообщение (нативные таблицы/заголовки; Bot API 10.1+).
# false → обычный текст. Фолбэк на текст срабатывает и автоматически при ошибке rich.
TELEGRAM_RICH=true

# --- Голосовые сообщения / STT (Фаза 9) ---
# true → распознавать голосовые локальным whisper.cpp (нужны ffmpeg + whisper-cli + модель).
WHISPER_ENABLED=false
# Путь к бинарю whisper.cpp (например /opt/whisper.cpp/build/bin/whisper-cli)
WHISPER_BIN=whisper-cli
# Путь к ggml-модели (например /opt/whisper.cpp/models/ggml-medium-q5_0.bin)
WHISPER_MODEL=
# Язык распознавания: auto | ru | en | ...
WHISPER_LANG=auto
# Число потоков whisper (по числу vCPU)
WHISPER_THREADS=2
# Таймаут распознавания, мс
WHISPER_TIMEOUT_MS=120000
# Путь/имя ffmpeg
FFMPEG_BIN=ffmpeg

# ОПЦИОНАЛЬНО (контейнеры/CI). Основной путь — авторизация на сервере через `claude /login`
# под тем же пользователем, что и сервис: тогда токен НЕ нужен (claude берёт креды из ~/.claude/,
# на mac — из keychain). Задайте только если не хотите интерактивный логин на машине.
# CLAUDE_CODE_OAUTH_TOKEN=
# ВАЖНО: НЕ задавать ANTHROPIC_API_KEY — иначе оплата по токенам через API.

# --- WHOOP интеграция (Фаза WHOOP) ---
# Реквизиты приложения из WHOOP Developer Dashboard.
WHOOP_CLIENT_ID=
# Используется и для обмена OAuth-токенов, и как секрет HMAC-подписи вебхуков.
WHOOP_CLIENT_SECRET=
# Redirect/Callback URL — ТОЧНО как зарегистрирован в WHOOP Dashboard (через Cloudflare Tunnel).
WHOOP_REDIRECT_URI=https://<host>/whoop/oauth/callback
# Секрет проверки подписи вебхуков. Пусто → берётся WHOOP_CLIENT_SECRET.
WHOOP_WEBHOOK_SECRET=
# Допуск свежести timestamp вебхука (анти-replay), сек. По умолчанию 300.
WHOOP_WEBHOOK_TOLERANCE_SEC=300
# Интервал воркера синхронизации (разбор pending-вебхуков → дотяжка из API), сек. По умолчанию 30.
WHOOP_SYNC_INTERVAL_SEC=30
# Интервал мониторинга (алерт владельцу в Telegram при росте failed-событий), сек. По умолчанию 300.
WHOOP_MONITOR_INTERVAL_SEC=300
# Ключ AES-256-GCM для шифрования токенов в БД. 32 байта base64: `openssl rand -base64 32`.
WHOOP_TOKEN_ENC_KEY=
# (OAuth/API эндпоинты и scopes WHOOP зашиты в код — src/whoop/whoop.constants.ts — env не нужны.)
# Секрет для защиты /whoop/oauth/start и /whoop/admin/backfill: open как ...?key=<этот секрет>.
# Тем же ключом MCP-тула mcp__whoop__backfill авторизует запуск (env MCP: WHOOP_ADMIN_SECRET).
# Без верного ключа эндпоинт отдаёт 404. Сгенерировать: openssl rand -hex 16
WHOOP_CONNECT_SECRET=

# --- Внешняя БД для данных WHOOP (TypeORM/Postgres, Фаза 1+) ---
# Managed Postgres. Sessions-БД (DB_PATH выше) это НЕ затрагивает — она остаётся на SQLite.
DATABASE_URL=postgres://user:pass@host:5432/db?sslmode=require
# Включить SSL в TypeORM (managed-провайдеры обычно требуют).
DATABASE_SSL=true
# Read-only подключение для MCP (отдельная роль с GRANT SELECT). Пусто → берётся DATABASE_URL.
WHOOP_MCP_DATABASE_URL=

# --- Планировщик задач (Scheduler) ---
# Тикер раз в N секунд забирает due-задачи из таблицы scheduled_task и шлёт промпт в Claude.
SCHEDULER_TICK_SEC=60
# Максимум задач за один тик (ограничивает всплеск запусков Claude).
SCHEDULER_BATCH=5
# Секрет для /scheduler/tasks (CRUD из MCP). Без верного ключа эндпоинт отдаёт 404.
# Им же MCP-тулы mcp__scheduler__* авторизуют вызовы (env MCP: SCHEDULER_ADMIN_SECRET).
# Сгенерировать: openssl rand -hex 16
SCHEDULER_ADMIN_SECRET=
# Адрес приложения для MCP-процесса scheduler (по умолчанию http://127.0.0.1:3000).
SCHEDULER_APP_URL=http://127.0.0.1:3000

# --- Cloudflare Tunnel (инфраструктура; приложением НЕ читается) ---
# Публичный hostname под /whoop/* задаётся в конфиге cloudflared (~/.cloudflared/config.yml),
# а не здесь. Наружу доступен только путь /whoop/*; приложение слушает 127.0.0.1. См. DEPLOY.md.
